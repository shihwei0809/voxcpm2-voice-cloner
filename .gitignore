# .gitignore

# Python 虛擬環境
.venv/
venv/

# 模型權重（太大，不進 repo）
checkpoints/
pretrained_models/
*.safetensors
*.pth

# 內嵌音頻的 HTML（含 base64，不上傳）
*_embedded.html

# 影片輸出
*.mp4

# 音檔（含 voices/ 內的參考音，屬個人資料不進版控）
ref_voice.wav
*.wav
output/

# 聲音資料夾（每個人的參考音與逐字稿，本地保留但不進版控）
voices/

# GPU 類型標記
.gpu_type

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# 系統
desktop.ini
*.tmp
~$*
.DS_Store
Thumbs.db

# 敏感資料
.env
*.key
credentials.*
